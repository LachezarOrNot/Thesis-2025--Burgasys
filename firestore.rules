rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return isSignedIn() && userDoc(request.auth.uid).data.role == 'admin';
    }

    function isOrgAdmin(orgId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.adminUsers;
    }

    function isOrgRole() {
      return isSignedIn() &&
        userDoc(request.auth.uid).data.role in ['school', 'university', 'firm'];
    }

    function canManageEvent(eventId) {
      return isSignedIn() && (
        isAdmin() ||
        get(/databases/$(database)/documents/events/$(eventId)).data.createdBy == request.auth.uid
      );
    }

    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.approved == resource.data.approved &&
          request.resource.data.approvalRequested == resource.data.approvalRequested &&
          request.resource.data.affiliatedOrganizationId == resource.data.affiliatedOrganizationId
        )
      );
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /organizations/{orgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.auth.uid in request.resource.data.adminUsers;
      allow update, delete: if isSignedIn() && (isAdmin() || isOrgAdmin(orgId));
    }

    match /userApprovalRequests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update, delete: if isSignedIn() && isAdmin();
    }

    match /affiliationRequests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.studentUid == request.auth.uid;
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.studentUid == request.auth.uid ||
        isOrgAdmin(resource.data.organizationId)
      );
      allow update, delete: if isSignedIn() && (
        isAdmin() || isOrgAdmin(resource.data.organizationId)
      );
    }

    match /eventCreationRequests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update, delete: if isSignedIn() && isAdmin();
    }

    match /events/{eventId} {
      allow read: if resource.data.status == 'published' || (
        isSignedIn() && (isAdmin() || resource.data.createdBy == request.auth.uid)
      );
      allow create: if isSignedIn() &&
        request.resource.data.createdBy == request.auth.uid &&
        (isAdmin() || isOrgRole());
      allow update, delete: if isSignedIn() &&
        (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    match /eventRegistrations/{registrationId} {
      allow create: if isSignedIn() && request.resource.data.userUid == request.auth.uid;
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.userUid == request.auth.uid ||
        canManageEvent(resource.data.eventId)
      );
      allow update, delete: if isSignedIn() && (
        isAdmin() ||
        resource.data.userUid == request.auth.uid ||
        canManageEvent(resource.data.eventId)
      );
    }

    match /chatMessages/{messageId} {
      allow create: if isSignedIn() && request.resource.data.senderUid == request.auth.uid;
      allow read: if isSignedIn();
      allow update, delete: if isSignedIn() &&
        (isAdmin() || resource.data.senderUid == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow read, update, delete: if isSignedIn() &&
        (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /activeCalls/{callId} {
      allow read, write: if isSignedIn();
    }

    match /scheduledDeletions/{userId} {
      allow create, read, update, delete: if isSignedIn() &&
        (isAdmin() || request.auth.uid == userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}